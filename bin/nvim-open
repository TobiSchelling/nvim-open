#!/usr/bin/env bash
# nvim-open — open files in Neovim inside a Ghostty window.
#
# Default (shared) mode: all files land as tabs in ONE Ghostty+Neovim window,
# driven by a persistent nvim --listen server. Parallel-safe: many concurrent
# invocations (e.g. from an agent) converge on a single window instead of
# spawning a storm of GUI windows.
#
# Usage:
#   nvim-open [FILE...]            open FILE(s) as tabs in the shared window
#   nvim-open -w|--window FILE...  open each FILE in its own Ghostty window
#   nvim-open                      open a blank shared window
#   nvim-open -h|--help            this help
#
# Env: GHOSTTY_APP, NVIM_BIN override locations.
set -euo pipefail

PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

GHOSTTY_APP="${GHOSTTY_APP:-/Applications/Ghostty.app}"
NVIM_BIN="${NVIM_BIN:-$(command -v nvim || true)}"

cache="${XDG_CACHE_HOME:-$HOME/.cache}/nvim-open"
SOCK="$cache/server.sock"
LOCKDIR="$cache/lock.d"
mkdir -p "$cache"

die() { printf 'nvim-open: %s\n' "$*" >&2; exit 1; }
[[ -n "$NVIM_BIN" ]] || die "nvim not found on PATH"
[[ -d "$GHOSTTY_APP" ]] || die "Ghostty.app not found at $GHOSTTY_APP (set GHOSTTY_APP)"

mode="shared"
files=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -w|--window) mode="window" ;;
    -h|--help) sed -n '2,18p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    --) shift; while [[ $# -gt 0 ]]; do files+=("$1"); shift; done; break ;;
    -*) die "unknown option: $1 (use -- to pass paths starting with -)" ;;
    *) files+=("$1") ;;
  esac
  shift
done

abspath() { python3 -c 'import os,sys; print(os.path.abspath(os.path.expanduser(sys.argv[1])))' "$1"; }

abs=()
for f in "${files[@]:-}"; do
  [[ -n "$f" ]] && abs+=("$(abspath "$f")")
done

activate_ghostty() { osascript -e 'tell application "Ghostty" to activate' >/dev/null 2>&1 || true; }

server_alive() {
  [[ -S "$SOCK" ]] || return 1
  "$NVIM_BIN" --server "$SOCK" --remote-expr '1' >/dev/null 2>&1
}

# macOS only lets us start Ghostty via `open`, and `open --args -e CMD ARGS...`
# mis-parses a multi-token command — each extra token (nvim's flags, the socket,
# the file path) spawns its OWN window. So we never pass arguments through `-e`:
# we hand Ghostty a single zero-arg launcher script that starts the Neovim
# server, then feed files to it over the socket with --remote/--remote-tab.
# `--window-save-state=never` keeps a saved split/layout from being restored.
LAUNCHER="$cache/server-launch.sh"

write_server_launcher() {  # $1 = optional first file, loaded at nvim startup
  local first="${1:-}"
  {
    echo '#!/usr/bin/env bash'
    echo 'PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"'
    if [[ -n "$first" ]]; then
      printf 'exec %q --listen %q %q\n' "$NVIM_BIN" "$SOCK" "$first"
    else
      printf 'exec %q --listen %q\n' "$NVIM_BIN" "$SOCK"
    fi
  } > "$LAUNCHER"
  chmod +x "$LAUNCHER"
}

ghostty_launch() {  # $1 = absolute path to a zero-arg launcher script
  open -na "$GHOSTTY_APP" --args --window-save-state=never -e "$1"
}

# --- window mode: one Ghostty window per file (no shared server) ---
if [[ "$mode" == "window" ]]; then
  find "$cache" -name 'win.*.sh' -mmin +60 -delete 2>/dev/null || true
  launch_one() {  # $1 = file (may be empty)
    local f="$1" tmp
    tmp="$(mktemp "$cache/win.XXXXXX.sh")"
    {
      echo '#!/usr/bin/env bash'
      echo 'PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"'
      if [[ -n "$f" ]]; then printf 'exec %q %q\n' "$NVIM_BIN" "$f"
      else printf 'exec %q\n' "$NVIM_BIN"; fi
    } > "$tmp"
    chmod +x "$tmp"
    ghostty_launch "$tmp"
  }
  if [[ ${#abs[@]} -eq 0 ]]; then
    launch_one ""
  else
    for f in "${abs[@]}"; do launch_one "$f"; done
  fi
  exit 0
fi

# --- shared mode: serialize "check-or-launch server" (macOS has no flock(1)) ---
acquire_lock() {
  local waited=0
  until mkdir "$LOCKDIR" 2>/dev/null; do
    sleep 0.1; waited=$((waited + 1))
    [[ $waited -gt 200 ]] && rmdir "$LOCKDIR" 2>/dev/null || true   # 20s stale-lock guard
  done
  trap 'rmdir "$LOCKDIR" 2>/dev/null || true' EXIT
}

acquire_lock

launched_now=false
if ! server_alive; then
  [[ -e "$SOCK" ]] && rm -f "$SOCK"
  write_server_launcher "${abs[0]:-}"   # bake first file in: loaded at startup, no race
  ghostty_launch "$LAUNCHER"
  for _ in $(seq 1 150); do server_alive && break; sleep 0.1; done   # up to ~15s
  launched_now=true
fi

if [[ ${#abs[@]} -gt 0 ]]; then
  if $launched_now; then
    # First file already loaded by the launcher; add any remaining files as tabs.
    [[ ${#abs[@]} -gt 1 ]] && "$NVIM_BIN" --server "$SOCK" --remote-tab "${abs[@]:1}" >/dev/null 2>&1 || true
  else
    "$NVIM_BIN" --server "$SOCK" --remote-tab "${abs[@]}" >/dev/null 2>&1 || true
  fi
fi
activate_ghostty
